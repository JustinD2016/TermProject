<!DOCTYPE html>
<html lang="en">

{{> fragments/html_header}}
<body>
{{> fragments/top_bar}}

<div class="container framed">
    <div class="center-align"><h2>Actor Lookup</h2></div>
        <div class="center-align">
        <p>Search for an actor by name to see their information.</p>
        <form method="get" action="/lookup">
            <input type="text" name="actorname" placeholder="Enter actor name" value="{{actorName}}">
            <button type="submit">Search</button>
        </form>
    </div>

{{#searched}}
<div class="framed" style="margin: 16pt; padding: 8pt 16pt;">

    {{#foundActor}}
        <h3>{{actor.firstName}} {{actor.lastName}}</h3>

        <p><strong>Actor ID:</strong> {{actor.actorId}}</p>
        <p><strong>Birth Year:</strong> {{actor.birthYear}}</p>
        <p><strong>Death Year:</strong> {{actor.deathYearDisplay}}</p>
        
        </div>

        <h3 style="margin: 16pt;">Known Titles</h3>
        <div class="framed" style="margin: 16pt;">
            <table class="full">

            <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Year</th>
                <th>Genres</th>
            </tr>

            {{#actor.titles}}
            <tr>
                <td>{{primaryName}}</td>
                <td>{{titleType}}</td>
                <td>{{releaseYear}}</td>
                <td>{{genres}}</td>
            </tr>
            {{/actor.titles}}
        </table>
        </div>
    {{/foundActor}}

    {{^foundActor}}
        <p>No actor found for "{{actorName}}". Try checking the spelling.</p>
    {{/foundActor}}
</div>
{{/searched}}

</div>
{{> fragments/footer}}
</body>
</html>

<!DOCTYPE html>
<html lang="en">
{{> fragments/html_header}}

<body>

    {{> fragments/top_bar}}

    <div class="container framed">

        {{> fragments/error_message}}

        <!-- Page header -->
        <div class="center-align">
            <h2>{{username}}'s Profile</h2>
        </div>

        <div class="center-align">
            <p><strong>{{followingCount}}</strong> Following &nbsp;|&nbsp; <strong>{{followerCount}}</strong> Followers</p>
        </div>

        <div class="container framed">
    <h3>Today's Game</h3>
    {{#todayPlayed}}
        {{#todaySolved}}
            <p> Solved in <strong>{{todayGuessesUsed}}</strong> guess(es)!</p>
        {{/todaySolved}}
        {{^todaySolved}}
            <p> Not solved today — better luck tomorrow!</p>
        {{/todaySolved}}
    {{/todayPlayed}}
    {{^todayPlayed}}
        <p>You haven't played today's game yet!</p>
    {{/todayPlayed}}
</div>

<div class="container framed">
    <h3>Friends' Activity Today</h3>
    {{#followingStatus}}
    <p>
        <strong>{{username}}</strong> —
        {{#played}}
            {{#solved}} Solved in {{guessesUsed}} guess(es){{/solved}}
            {{^solved}} Played but didn't solve{{/solved}}
        {{/played}}
        {{^played}} Hasn't played yet{{/played}}
    </p>
    {{/followingStatus}}
    {{^followingStatus}}
    <p>You aren't following anyone yet.</p>
    {{/followingStatus}}
</div>

<div class="container framed">
    <h3>Win Streak</h3>
    <p>Current Streak: <strong>{{currentStreak}}</strong></p>
    <p>Best Streak: <strong>{{maxStreak}}</strong></p>
</div>

    </div>

    {{> fragments/footer}}

</body>
</html>